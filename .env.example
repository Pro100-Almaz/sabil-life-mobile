# Backend integration. Copy to `.env` (gitignored) and adjust per device.
#
# Host machine, iOS simulator, web:
#   API_BASE_URL=http://localhost:8000/api/v1
#
# Android emulator (host is reached via 10.0.2.2):
#   API_BASE_URL=http://10.0.2.2:8000/api/v1
#
# Physical device on the same LAN:
#   API_BASE_URL=http://<your-host-LAN-IP>:8000/api/v1
#
# Staging / production: ask the backend team for the URL.

API_BASE_URL=http://localhost:8000/api/v1
